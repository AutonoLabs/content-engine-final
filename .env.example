# Content Engine — Keys & Config
#
# Copy to `.env` and fill in. Never commit `.env` to git.
# The repo's `.gitignore` already excludes it.
#
# All paths in this repo are relative — no internal-infrastructure references.
# Place your `.env` at the repo root: `content-engine-final/.env`

# ─── Required keys ────────────────────────────────────────────────────────

# Blotato (multi-platform publishing)
# Get from: https://my.blotato.com/settings/api
BLOTATO_API_KEY=your_blotato_api_key_here


# ─── Optional keys ────────────────────────────────────────────────────────

# XAI / Twitter data (for trend research via x_search)
# Get from: https://console.x.ai
XAI_API_KEY=

# Anthropic (alternative LLM provider for agent runs)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Replicate (image generation; preferred over vendor-direct APIs)
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Higgsfield (video generation — currently manual-paste workflow;
# API key reserved for future automation)
# Get from: https://higgsfield.ai/settings/api
HIGGSFIELD_API_KEY=


# ─── Budget notes ─────────────────────────────────────────────────────────

# Higgsfield Ultra: $99/mo annual, 6000 credits/mo (June 2026 pricing)
# Manual-media mode: user generates in Higgsfield via web UI,
# downloads, renames to the packet contract, drops in brands/<brand>/inbox/


# ─── Security ─────────────────────────────────────────────────────────────

# Never paste keys in chat. Drop them directly into `.env`.
# Rotate any key that has been visible in a screen share, screenshot,
# or chat transcript.